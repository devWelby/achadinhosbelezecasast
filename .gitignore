# ==============================================================================
# Gitignore para Frontend Estático (Achados Beleza e Casa St)
# ==============================================================================

# 1. Arquivos de Sistema Operacional
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# 2. Configurações de IDEs e Editores (VS Code, WebStorm, etc)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 3. Logs e Arquivos de Debug
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 4. Variáveis de Ambiente e Segredos (Extremamente Importante)
# Nunca suba chaves de API, senhas ou URLs sensíveis privadas para o GitHub!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
secrets.json

# 5. Dependências do Node.js (Caso você use NPM no futuro para algum pacote)
node_modules/
jspm_packages/

# 6. Pastas de Build/Distribuição (Caso use Netlify CLI ou Vite no futuro)
dist/
build/
.netlify/
.cache/
